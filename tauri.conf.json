{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VSCode Android",
  "version": "1.0.0",
  "identifier": "com.vscode.android",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VSCode Android",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://github.com wss://*; img-src 'self' data: https://*; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["apk", "aab"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE"
      ],
      "keystorePath": null,
      "keystorePassword": null,
      "keyPassword": null,
      "keyAlias": null
    }
  },
  "plugins": {
    "fs": {
      "scope": ["**"]
    },
    "http": {
      "scope": ["https://api.github.com", "https://github.com", "https://*.github.dev", "wss://*"]
    },
    "websocket": {
      "scope": ["wss://*.github.dev", "wss://api.github.com"]
    },
    "store": {
      "path": "vscode_android_store.bin"
    }
  }
}
