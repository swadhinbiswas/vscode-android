{
  "name": "vscode-android",
  "version": "1.0.0",
  "description": "VS Code-like Android app with Tauri v2 and GitHub Codespaces sync",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc && vite build",
    "preview": "vite preview",
